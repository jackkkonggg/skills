{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Dark Modern",
  "author": "VSCode Port",
  "themes": [
    {
      "name": "Dark Modern",
      "appearance": "dark",
      "style": {
        "background": "#1f1f1fff",
