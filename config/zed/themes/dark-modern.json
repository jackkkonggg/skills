          "attribute.jsx": { "color": "#9cdcfeff" },
          "boolean": { "color": "#569cd6ff" },
          "comment": { "color": "#6a9955ff" },
          "comment.doc": { "color": "#6a9955ff" },
          "constant": { "color": "#569cd6ff" },
          "constant.builtin": { "color": "#569cd6ff" },
          "constructor": { "color": "#4ec9b0ff" },
          "embedded": { "color": "#d4d4d4ff" },
          "emphasis": { "font_style": "italic" },
          "emphasis.strong": { "font_weight": 700 },
          "enum": { "color": "#4ec9b0ff" },
          "function": { "color": "#dcdcaaff" },
          "hint": { "color": "#6e7681ff" },
          "keyword": { "color": "#c586c0ff" },
          "keyword.control": { "color": "#c586c0ff" },
          "keyword.declaration": { "color": "#569cd6ff" },
          "keyword.import": { "color": "#c586c0ff" },
          "label": { "color": "#9cdcfeff" },
          "link_text": { "color": "#569cd6ff" },
          "link_uri": { "color": "#ce9178ff" },
          "namespace": { "color": "#4ec9b0ff" },
          "number": { "color": "#b5cea8ff" },
          "operator": { "color": "#d4d4d4ff" },
          "predictive": { "color": "#4b4b4bff" },
          "preproc": { "color": "#c586c0ff" },
          "primary": { "color": "#ccccccff" },
          "property": { "color": "#9cdcfeff" },
          "punctuation": { "color": "#d4d4d4ff" },
          "punctuation.bracket": { "color": "#d4d4d4ff" },
          "punctuation.bracket.jsx": { "color": "#808080ff" },
          "punctuation.delimiter": { "color": "#d4d4d4ff" },
          "punctuation.delimiter.jsx": { "color": "#808080ff" },
          "punctuation.list_marker": { "color": "#569cd6ff" },
          "punctuation.special": { "color": "#569cd6ff" },
          "selector": { "color": "#d7ba7dff" },
          "string": { "color": "#ce9178ff" },
          "string.escape": { "color": "#d7ba7dff" },
          "string.regex": { "color": "#d16969ff" },
          "string.special": { "color": "#ce9178ff" },
          "string.special.symbol": { "color": "#ce9178ff" },
          "tag": { "color": "#569cd6ff" },
          "tag.doctype": { "color": "#569cd6ff" },
          "tag.jsx": { "color": "#569cd6ff" },
          "text.literal": { "color": "#ce9178ff" },
          "title": { "color": "#dcdcaaff", "font_weight": 700 },
          "type": { "color": "#4ec9b0ff" },
          "type.builtin": { "color": "#4ec9b0ff" },
          "variable": { "color": "#9cdcfeff" },
          "variable.special": { "color": "#569cd6ff", "font_style": "italic" },
          "variable.parameter": { "color": "#9cdcfeff" },
          "variant": { "color": "#4ec9b0ff" }
