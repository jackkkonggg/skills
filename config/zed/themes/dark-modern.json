        "info": "#4daafc",
        "info.background": "#0078d420",
        "info.border": "#0078d440",
        "modified": "#0078d4ff",
        "predictive": "#4b4b4bff",
        "renamed": "#569cd6ff",
        "success": "#6a9955ff",
        "success.background": "#6a995520",
        "success.border": "#6a995540",
        "unreachable": "#6e7681ff",
        "warning": "#cca700ff",
        "warning.background": "#cca70020",
        "warning.border": "#cca70040",

