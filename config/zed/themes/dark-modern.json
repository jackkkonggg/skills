          {
            "cursor": "#4daafc",
            "background": "#4daafcff",
            "selection": "#4daafc3d"
          },
          {
            "cursor": "#4ec9b0ff",
            "background": "#4ec9b03d",
            "selection": "#4ec9b01a"
          },
          {
            "cursor": "#c586c0ff",
